---
import { authenticationApiDocsUrl } from './authenticationApiDocsUrl';
import { dataUseTermsAreEnabled, getRuntimeConfig, getWebsiteConfig } from '../../config';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { routes } from '../../routes/routes.ts';
import { getAuthBaseUrl } from '../../utils/getAuthUrl';

const clientConfig = getRuntimeConfig().public;
const keycloakUrl = getAuthBaseUrl();

const websiteConfig = getWebsiteConfig();

const organismKeys = Object.keys(websiteConfig.organisms);

const specLinkClass =
    'rounded border border-gray-300 px-3 py-1.5 text-sm font-medium text-primary-900 hover:border-primary-500 hover:bg-primary-50 hover:no-underline';
const cardClass = 'rounded-lg border border-gray-200 bg-white p-5 shadow-sm';

const docsFor = (specPath: string) => ({
    json: clientConfig.backendUrl + specPath,
    swagger: `${clientConfig.backendUrl}/swagger-ui/loculus?url=${encodeURIComponent(specPath)}`,
    scalar: `${clientConfig.backendUrl}/scalar-api-reference?url=${encodeURIComponent(specPath)}`,
});

const mainSpecs = [
    {
        title: 'Complete API',
        description: 'All backend endpoints and all query APIs in one OpenAPI document.',
        specPath: '/api-docs.json',
    },
    {
        title: 'General backend API',
        description: 'Backend endpoints excluding the organism and view query APIs.',
        specPath: '/api-docs/general.json',
    },
].map((spec) => ({ ...spec, links: docsFor(spec.specPath) }));

const databaseQuerySpecs = organismKeys
    .map((key) => ({
        key,
        title: websiteConfig.organisms[key].schema.organismName,
    }))
    .sort((a, b) => a.title.localeCompare(b.title))
    .map((spec) => ({
        ...spec,
        specPath: `/api-docs/query/${spec.key}.json`,
        links: docsFor(`/api-docs/query/${spec.key}.json`),
    }));

const viewQuerySpecs = Object.entries(websiteConfig.views)
    .map(([key, view]) => ({
        key,
        title: view.displayName,
    }))
    .sort((a, b) => a.title.localeCompare(b.title))
    .map((spec) => ({
        ...spec,
        specPath: `/api-docs/query/${spec.key}.json`,
        links: docsFor(`/api-docs/query/${spec.key}.json`),
    }));
---

<BaseLayout title='API documentation'>
    <div class='container mx-auto p-8'>
        <h1 class='title'>API documentation</h1>

        <div class='mb-10'>
            <p class='mt-4 mb-4'>
                There is a
                <a
                    href='https://swagger.io/tools/swagger-ui/'
                    class='underline text-primary-900 hover:text-primary-800 hover:no-underline'
                >
                    Swagger UI
                </a>
                for documentation and direct interaction with the APIs. For more tips on how to use the API, it is recommended
                to start with the
                <a
                    href={authenticationApiDocsUrl}
                    class='underline text-primary-900 hover:text-primary-800 hover:no-underline'
                >
                    API Authentication documentation.
                </a>
            </p>
            <p class='mt-4 mb-4'>
                WARNING: Swagger incorrectly displays NDJSON examples in JSON format. For endpoints that require NDJSON
                as input you must convert the JSON examples to NDJSON (e.g. by removing new lines) prior to testing.
            </p>
            {
                dataUseTermsAreEnabled() && (
                    <p class='mt-4 mb-4'>
                        By using our API you agree to our
                        <a
                            href={routes.datauseTermsPage()}
                            class='underline text-primary-900 hover:text-primary-800 hover:no-underline'
                        >
                            Data use terms
                        </a>
                        .
                    </p>
                )
            }
        </div>

        <section class='mb-10'>
            <h2 class='text-xl font-semibold text-primary-400 mb-4'>Backend API specifications</h2>
            <p class='mb-5'>Loculus is under continuous development and the endpoints are subject to change.</p>
            <div class='grid gap-4 md:grid-cols-2'>
                {
                    mainSpecs.map((spec) => (
                        <article class={cardClass}>
                            <h3 class='text-lg font-semibold'>{spec.title}</h3>
                            <p class='mt-2 text-sm text-gray-700'>{spec.description}</p>
                            <div class='mt-4 flex flex-wrap gap-2'>
                                <a class={specLinkClass} href={spec.links.json}>
                                    JSON
                                </a>
                                <a class={specLinkClass} href={spec.links.swagger}>
                                    Swagger
                                </a>
                                <a class={specLinkClass} href={spec.links.scalar}>
                                    Scalar
                                </a>
                            </div>
                            <div class='mt-4 text-sm'>
                                <span class='font-medium'>Spec:</span> <code>{spec.specPath}</code>
                            </div>
                        </article>
                    ))
                }
            </div>
            <div class='mt-6'>
                <span class='font-medium'>URL of backend server:</span>
                <code>{clientConfig.backendUrl}</code>
            </div>
        </section>

        <section class='mb-10'>
            <h2 class='text-xl font-semibold text-primary-400 mb-4'>Query API specifications - databases</h2>
            <div class='grid gap-3 md:grid-cols-2 xl:grid-cols-3'>
                {
                    databaseQuerySpecs.map((spec) => (
                        <article class={cardClass}>
                            <div class='flex items-start justify-between gap-3'>
                                <div>
                                    <h3 class='font-semibold'>{spec.title}</h3>
                                </div>
                                <code class='text-xs text-gray-600'>{spec.key}</code>
                            </div>
                            <div class='mt-4 flex flex-wrap gap-2'>
                                <a class={specLinkClass} href={spec.links.json}>
                                    JSON
                                </a>
                                <a class={specLinkClass} href={spec.links.swagger}>
                                    Swagger
                                </a>
                                <a class={specLinkClass} href={spec.links.scalar}>
                                    Scalar
                                </a>
                            </div>
                        </article>
                    ))
                }
            </div>
        </section>

        <section class='mb-10'>
            <h2 class='text-xl font-semibold text-primary-400 mb-4'>Query API specifications - views</h2>
            <div class='grid gap-3 md:grid-cols-2 xl:grid-cols-3'>
                {
                    viewQuerySpecs.map((spec) => (
                        <article class={cardClass}>
                            <div class='flex items-start justify-between gap-3'>
                                <div>
                                    <h3 class='font-semibold'>{spec.title}</h3>
                                </div>
                                <code class='text-xs text-gray-600'>{spec.key}</code>
                            </div>
                            <div class='mt-4 flex flex-wrap gap-2'>
                                <a class={specLinkClass} href={spec.links.json}>
                                    JSON
                                </a>
                                <a class={specLinkClass} href={spec.links.swagger}>
                                    Swagger
                                </a>
                                <a class={specLinkClass} href={spec.links.scalar}>
                                    Scalar
                                </a>
                            </div>
                        </article>
                    ))
                }
            </div>
        </section>

        <div>
            <h2 class='text-xl font-semibold text-primary-400 mb-4'>Keycloak server</h2>
            <div>
                We use the open source software <a href='https://www.keycloak.org/'>Keycloak</a> for authentication.
            </div>
            <div class='mt-2'>
                <span class='font-medium'>URL of Keycloak server:</span>
                <code>{keycloakUrl}</code>
            </div>
        </div>
    </div>
</BaseLayout>

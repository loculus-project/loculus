---
import { OrganismDocumentEditor } from '../../../../../components/admin/OrganismDocumentEditor';
import { getRuntimeConfig } from '../../../../../config';
import AdminConfigLayout from '../../../../../layouts/AdminConfigLayout.astro';
import { AdminConfigError, getAdminConfigClient } from '../../../../../services/adminConfigClient';
import type { CanonicalOrganismConfig, OrganismDraftResponse } from '../../../../../types/loculusConfig';

const key = Astro.params.key!;
const session = Astro.locals.session!;
const client = await getAdminConfigClient(session);
const publicBackendUrl = getRuntimeConfig().public.backendUrl;

let isReleased = false;
let loadError: string | null = null;
try {
    const list = await client.listOrganisms();
    const found = list.organisms.find((o) => o.key === key);
    if (found === undefined) {
        return Astro.redirect('/admin/config/organisms');
    }
    isReleased = found.status === 'released';
} catch (e) {
    loadError = AdminConfigError.isInstance(e) ? (e.body.message ?? e.body.error) : String(e);
}

if (isReleased) {
    return Astro.redirect(`/admin/config/organisms/${encodeURIComponent(key)}/edit`);
}

let initialDraft: OrganismDraftResponse | null = null;
if (loadError === null) {
    try {
        initialDraft = await client.getOrganismDraft(key);
    } catch (e) {
        loadError = AdminConfigError.isInstance(e) ? (e.body.message ?? e.body.error) : String(e);
    }
}

const seedConfig: CanonicalOrganismConfig = {
    schema: {
        organismName: key,
        metadata: [],
        externalMetadata: [],
        inputFields: [],
        tableColumns: [],
        files: [],
        linkOuts: [],
    },
    referenceGenome: {
        nucleotideSequences: [{ name: 'main', sequence: '' }],
        genes: [],
    },
};
---

<AdminConfigLayout title={`Draft · ${key}`}>
    {loadError !== null && <p class='text-red-600 mb-4'>Failed to load: {loadError}</p>}
    {
        loadError === null && (
            <OrganismDocumentEditor
                accessToken={session.token!.accessToken}
                backendUrl={publicBackendUrl}
                organismKey={key}
                initialDraft={initialDraft}
                seedConfig={seedConfig}
                client:load
            />
        )
    }
</AdminConfigLayout>
